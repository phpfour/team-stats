# github-stats environment variables.
# Copy to `.env` for local dev, or paste into Forge's "Environment" tab for prod.

# --- Database ---
DATABASE_URL=mysql://github_stats:password@127.0.0.1:3306/github_stats

# --- GitHub OAuth (for dashboard login) ---
# Create at https://github.com/settings/developers
# Authorization callback URL:
#   local:  http://localhost:3000/api/auth/callback
#   prod:   https://stats.klasio.dev/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- GitHub API (for sync / backfill) ---
# Fine-grained PAT with Contents/Issues/Metadata/Pull requests = Read on all klasio repos,
# or a classic PAT with `repo` + `read:org` scopes.
GITHUB_SYNC_TOKEN=

# --- App config ---
GITHUB_ORG=klasio

# --- Session signing ---
# Generate with: openssl rand -hex 32
SESSION_SECRET=
